			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Raknya kosong semua..."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Barang yang sisa ada di kardus pojok. Nggak banyak"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Berarti besok kita mulai dari sisa itu dulu?"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Iya. Pelan-pelan."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Pak Beni masih mau bantu?"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Bapak biasa sif pagi dari dulu. Besok juga begitu"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Tapi saya sekolah."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Makanya kamu sekolah dulu. Pulang sekolah baru ke sini."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Maaf ya, Pak. Jadi ngerepotin."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Kalau Bapak merasa repot, Bapak nggak akan datang hari ini."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "...Makasih, Pak."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Kuncinya kamu pegang. Agak macet, jadi pas diputer angkat sedikit"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Iya, pak."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Bapak pulang dulu. Besok kita mulai bersihin toko ini."
		}
